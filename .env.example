# ============================================================
# ライフアップ専用アプリ — 環境変数
# ============================================================

# --- Google スプレッドシート連携（バックエンド / 認証）---------
# google-apps-script/Code.gs をデプロイして取得した値を設定します。
# 詳しい手順は google-apps-script/README.md を参照してください。
SHEETS_API_URL=https://script.google.com/macros/s/xxxxxxxx/exec
SHEETS_API_SECRET=任意の長いランダム文字列（GAS側のスクリプトプロパティと一致させる）

# セッションCookieの署名鍵（未設定の場合は SHEETS_API_SECRET を流用）
SESSION_SECRET=別の長いランダム文字列

# --- AIキャラクター生成（任意）--------------------------------
# サーバー側に固定キーを置く場合のみ。通常はアプリの設定画面から登録します。
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# ※ これらが未設定でもアプリは「デモモード」で動作します
#    （ログインは誰でも通り、データは保存されません）
